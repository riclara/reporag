        {
          "type": "json",
          "path": "packages/mcp-server/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/mcp-server/package.json",
          "jsonpath": "$.dependencies['@reporag/app']"
        },
        {
          "type": "json",
          "path": "packages/mcp-server/package.json",
          "jsonpath": "$.dependencies['@reporag/shared']"
        },
        {
          "type": "json",
          "path": "packages/shared/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages[''].version"
        },
        {
          "type": "json",
