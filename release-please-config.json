        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages['packages/app'].dependencies['@reporag/shared']"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages['packages/cli'].version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages['packages/domain'].version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages['packages/domain'].dependencies['@reporag/adapters']"
        },
        {
          "type": "json",
